# Telegram Bot (production)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Dev Bot (used as main bot in development, receives error notifications in production)
TELEGRAM_DEV_BOT_TOKEN=your_dev_bot_token_here
ERROR_NOTIFY_CHAT_ID=your_telegram_user_id

# Gemini API
GEMINI_API_KEY=your_gemini_api_key_here

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_supabase_service_key_here

# Google Cloud (for Vision API)
GCP_CLIENT_EMAIL=your-service-account@project.iam.gserviceaccount.com
GCP_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Server
PORT=3333

# Deployment (production only)
NODE_ENV=development
WEBHOOK_URL=https://billnot.afishafiraa.cloud
CRON_SECRET=your_random_secret_here

# Cloudflare Tunnel
CLOUDFLARE_TUNNEL_TOKEN=your_tunnel_token_here
